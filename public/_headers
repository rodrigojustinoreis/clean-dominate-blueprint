# Security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Cache static assets aggressively (hashed filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images
*.jpg
  Cache-Control: public, max-age=2592000
*.png
  Cache-Control: public, max-age=2592000
*.webp
  Cache-Control: public, max-age=2592000
*.svg
  Cache-Control: public, max-age=2592000
*.avif
  Cache-Control: public, max-age=2592000

# Cache fonts
*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Cache JS & CSS (hashed)
*.js
  Cache-Control: public, max-age=31536000, immutable
*.css
  Cache-Control: public, max-age=31536000, immutable

# HTML pages — stale-while-revalidate so cold-cache hits are served instantly
# from edge while Netlify refreshes in background. Covers all prerendered
# directory-style routes (/about/, /locations/bethesda-md, etc.) not just .html files.
# More-specific rules above (/assets/*, *.js, *.css) still win for static assets.
/*
  Cache-Control: public, max-age=0, stale-while-revalidate=86400

# Service worker and manifest
/manifest.json
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400
